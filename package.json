{
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "prettier": "3.8.3"
  },
  "lint-staged": {
    "central-pet-front/**/*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "pnpm --filter central-pet-front exec eslint --fix"
    ],
    "central-pet-back/{src,test}/**/*.{js,ts}": [
      "prettier --write",
      "pnpm --filter central-pet-back exec eslint --fix"
    ],
    "central-pet-back/scripts/**/*.js": [
      "prettier --write"
    ],
    "tests/**/*.{js,ts}": [
      "prettier --write"
    ],
    "*.{css,json,md}": "prettier --write",
    "scripts/**/*.{js}": "prettier --write"
  },
  "scripts": {
    "prepare": "husky",
    "dev:front": "pnpm --filter central-pet-front dev",
    "dev:back": "pnpm --filter central-pet-back dev",
    "dev:back:test": "pnpm --filter central-pet-back dev:test",
    "dev": "pnpm -r --parallel --if-present run dev",
    "dev:docker": "docker compose -f docker-compose.dev.yml up --build -d",
    "dev:docker:down": "docker compose -f docker-compose.dev.yml down",
    "dev:docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:docker:clean": "docker compose -f docker-compose.dev.yml down -v",
    "build:front": "pnpm --filter central-pet-front build",
    "build:back": "pnpm --filter central-pet-back build",
    "test:front": "pnpm --filter central-pet-front test:run",
    "test:e2e": "pnpm --filter central-pet-e2e-tests test",
    "test:e2e:ui": "pnpm --filter central-pet-e2e-tests test:ui",
    "test:e2e:install": "pnpm --filter central-pet-e2e-tests install-browsers",
    "test:back": "pnpm --filter central-pet-back test:setup && pnpm --filter central-pet-back test && pnpm --filter central-pet-back test:e2e",
    "test:all": "pnpm --filter central-pet-back test:setup && pnpm --filter central-pet-back test && pnpm --filter central-pet-back test:e2e && pnpm --filter central-pet-front test:run && pnpm --filter central-pet-e2e-tests test"
  },
  "packageManager": "pnpm@10.30.1"
}
