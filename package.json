{
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^10.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "only-allow": "^1.2.2",
    "prettier": "3.8.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": "prettier --write"
  },
  "scripts": {
    "prepare": "husky",
    "dev:front": "pnpm --filter central-pet-front dev",
    "dev:back": "pnpm --filter central-pet-back start:dev",
    "dev": "run-p dev:front dev:back",
    "build:front": "pnpm --filter central-pet-front build",
    "build:back": "pnpm --filter central-pet-back build"
  },
  "packageManager": "pnpm@10.30.1"
}
