# Configuração de desenvolvimento (exemplo)
# Copie para .env e ajuste conforme necessário

# Ambiente padrão de execução
# NODE_ENV=development

PORT=3000
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://centralpet:centralpet123@localhost:5432/centralpetdb
ENABLE_MOCK_PETS=false

# Throttling global (defaults da aplicação)
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
TERMS_VERSION=1.0.0
