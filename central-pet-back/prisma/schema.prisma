// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ROOT
  ADMIN
  PESSOA_FISICA
  ONG
}

enum PetSpecies {
  DOG
  CAT
}

enum PetSex {
  FEMALE
  MALE
}

enum PetSize {
  SMALL
  MEDIUM
  LARGE
}

enum PetStatus {
  AVAILABLE
  ADOPTED
  UNAVAILABLE
}

enum AdoptionRequestStatus {
  PENDING
  CONTACT_SHARED
  APPROVED
  REJECTED
  CANCELLED
}

enum PetHistoryEventType {
  CREATED
  TRANSFERRED
  ADOPTION_APPROVED
  RETURNED
  UPDATED
}

model User {
  id                   String             @id @default(uuid())
  fullName             String
  email                String             @unique
  role                 UserRole
  birthDate            DateTime?          @db.Date
  cpf                  String?            @unique
  organizationName     String?
  cnpj                 String?            @unique
  city                 String?
  state                String?
  phone                String?
  mobile               String?
  instagram            String?
  facebook             String?
  website              String?
  foundedAt            DateTime?          @db.Date
  passwordHash         String
  acceptedTermsAt      DateTime?
  acceptedTermsVersion String?
  mustChangePassword   Boolean            @default(false)
  deleted              Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  sessions             Session[]
  responsiblePets      Pet[]               @relation("ResponsibleUserPets")
  responsibleAdoptionRequests AdoptionRequest[] @relation("ResponsibleUserAdoptionRequests")
  adopterAdoptionRequests     AdoptionRequest[] @relation("AdopterAdoptionRequests")
  performedPetHistory  PetHistory[]       @relation("PerformedPetHistory")
  auditLogs            AuditLog[]         @relation("UserAuditLogs")
  reports              ModerationReport[] @relation("UserReports")
  resolvedReports      ModerationReport[] @relation("AdminResolvedReports")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
}

model Pet {
  id                 String             @id @default(uuid())
  name               String
  ageText            String
  species            PetSpecies
  breed              String
  sex                PetSex
  size               PetSize
  profilePhoto       String
  galleryPhotosJson  String?
  microchipped       Boolean            @default(false)
  vaccinated         Boolean            @default(false)
  neutered           Boolean            @default(false)
  dewormed           Boolean            @default(false)
  needsHealthCare    Boolean            @default(false)
  physicalLimitation Boolean            @default(false)
  visualLimitation   Boolean            @default(false)
  hearingLimitation  Boolean            @default(false)
  selectedPersonalitiesJson String         @default("[]")
  responsibleUserId  String
  sourceType         UserRole
  sourceName         String
  status             PetStatus          @default(AVAILABLE)
  deleted            Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  responsibleUser    User?              @relation("ResponsibleUserPets", fields: [responsibleUserId], references: [id], onDelete: Restrict)
  adoptionRequests   AdoptionRequest[]
  history            PetHistory[]

  @@index([status])
  @@index([species])
  @@index([responsibleUserId])
  @@index([deleted])
}

model AdoptionRequest {
  id                         String                @id @default(uuid())
  petId                      String
  responsibleUserId          String
  adopterId                  String
  adopterContactShareConsent Boolean               @default(false)
  responsibleContactShareConsent Boolean @default(false)
  message                    String
  status                     AdoptionRequestStatus @default(PENDING)
  note                       String?
  requestedAt                DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  version                    Int                   @default(0)

  pet                        Pet                   @relation(fields: [petId], references: [id], onDelete: Restrict)
  responsibleUser            User                  @relation("ResponsibleUserAdoptionRequests", fields: [responsibleUserId], references: [id], onDelete: Restrict)
  adopter                    User                  @relation("AdopterAdoptionRequests", fields: [adopterId], references: [id], onDelete: Restrict)

  @@index([responsibleUserId, requestedAt])
  @@index([adopterId])
  @@index([petId])

  @@unique([petId, adopterId])
}

model PetHistory {
  id                String              @id @default(uuid())
  petId             String
  eventType         PetHistoryEventType
  description       String
  fromResponsible   String?
  toResponsible     String?
  performedByUserId String?
  createdAt         DateTime            @default(now())

  pet               Pet                 @relation(fields: [petId], references: [id], onDelete: Restrict)
  performedByUser   User?               @relation("PerformedPetHistory", fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([petId])
  @@index([performedByUserId])
  @@index([eventType])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  targetId    String?
  targetType  String?
  details     Json?
  createdAt   DateTime @default(now())

  user        User     @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  DISMISSED
}

model ModerationReport {
  id           String   @id @default(uuid())
  reporterId   String
  targetType   String
  targetId     String
  reason       String
  status       ModerationStatus   @default(PENDING)
  resolvedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reporter     User     @relation("UserReports", fields: [reporterId], references: [id], onDelete: Restrict)
  resolvedBy   User?    @relation("AdminResolvedReports", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([status])
  @@index([targetId])
}
