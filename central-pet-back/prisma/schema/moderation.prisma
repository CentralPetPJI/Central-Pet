enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  DISMISSED
}

model ModerationReport {
  id           String           @id @default(uuid())
  reporterId   String
  targetType   String
  targetId     String
  reason       String
  status       ModerationStatus @default(PENDING)
  resolvedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  reporter     User             @relation("UserReports", fields: [reporterId], references: [id], onDelete: Restrict)
  resolvedBy   User?            @relation("AdminResolvedReports", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([status])
  @@index([targetId])
}
