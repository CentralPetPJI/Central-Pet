enum AdoptionRequestStatus {
  PENDING
  CONTACT_SHARED
  APPROVED
  REJECTED
  CANCELLED
}

model AdoptionRequest {
  id                             String                @id @default(uuid())
  petId                          String
  responsibleUserId              String
  adopterId                      String
  adopterContactShareConsent     Boolean               @default(false)
  responsibleContactShareConsent Boolean               @default(false)
  message                        String
  status                         AdoptionRequestStatus @default(PENDING)
  note                           String?
  requestedAt                    DateTime              @default(now())
  updatedAt                      DateTime              @updatedAt
  version                        Int                   @default(0)
  pet                            Pet                   @relation(fields: [petId], references: [id], onDelete: Restrict)
  responsibleUser                User                  @relation("ResponsibleUserAdoptionRequests", fields: [responsibleUserId], references: [id], onDelete: Restrict)
  adopter                        User                  @relation("AdopterAdoptionRequests", fields: [adopterId], references: [id], onDelete: Restrict)

  @@unique([petId, adopterId])
  @@index([responsibleUserId, requestedAt])
  @@index([adopterId])
  @@index([petId])
}
