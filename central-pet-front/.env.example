# Copie para .env e ajuste os valores conforme necessário

# API Base URL (default usado pelo front quando não informado)
# VITE_API_URL=http://localhost:3000/api

# Estratégia de autenticação (mock | session)
VITE_AUTH_STRATEGY=mock

# Exibe gate de escolha mock na interface (true | false)
# VITE_DISPLAY_MOCK_CHOICE_GATE=false
